#!/usr/bin/env bash
set -euo pipefail

usage() {
    cat <<'USAGE'
Usage:
  scripts/prototype-portable --platform linux-amd64 --phar <path> --runtime <path> --output .cursor/tmp/<dir>

Creates a proof-of-concept stud-portable directory from an existing PHAR and a
platform PHP runtime. Prototype outputs must stay under .cursor/tmp/.
USAGE
}

die() {
    echo "Error: $1" >&2
    exit 1
}

platform=""
phar_path=""
runtime_path=""
output_dir=""

while [ "$#" -gt 0 ]; do
    case "$1" in
        --platform)
            platform="${2:-}"
            shift 2
            ;;
        --phar)
            phar_path="${2:-}"
            shift 2
            ;;
        --runtime)
            runtime_path="${2:-}"
            shift 2
            ;;
        --output)
            output_dir="${2:-}"
            shift 2
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            die "Unknown argument: $1"
            ;;
    esac
done

[ -n "$platform" ] || die "--platform is required"
[ -n "$phar_path" ] || die "--phar is required"
[ -n "$runtime_path" ] || die "--runtime is required"
[ -n "$output_dir" ] || die "--output is required"

[ "$platform" = "linux-amd64" ] || die "Only linux-amd64 is supported by this prototype"
[ -f "$phar_path" ] || die "PHAR not found: $phar_path"
[ -f "$runtime_path" ] || die "Runtime not found: $runtime_path"
[ -x "$runtime_path" ] || die "Runtime must be executable: $runtime_path"

case "$output_dir" in
    .cursor/tmp|.cursor/tmp/*) ;;
    *) die "Prototype output must be under .cursor/tmp/" ;;
esac

rm -rf "$output_dir"
mkdir -p "$output_dir/runtime" "$output_dir/app"

cp "$runtime_path" "$output_dir/runtime/php"
cp "$phar_path" "$output_dir/app/stud.phar"

cat > "$output_dir/stud" <<'LAUNCHER'
#!/usr/bin/env sh
set -eu

bin_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
exec "$bin_dir/runtime/php" "$bin_dir/app/stud.phar" "$@"
LAUNCHER

chmod 0755 "$output_dir/stud" "$output_dir/runtime/php"

cat > "$output_dir/README.md" <<README
# stud-portable prototype

Platform: $platform

This directory is a proof-of-concept portable stud layout. The \`stud\` launcher
uses the bundled \`runtime/php\` executable to run \`app/stud.phar\`, so users do
not need PHP on PATH for this artifact shape.

Smoke checks:

\`\`\`bash
./stud --version
echo '{}' | ./stud help --agent
echo '{"skipJira":true,"skipGit":true}' | ./stud config:validate --agent
\`\`\`
README

echo "Created portable prototype at $output_dir"
