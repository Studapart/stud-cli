#!/usr/bin/env bash
set -euo pipefail

usage() {
    cat <<'USAGE'
Usage:
  scripts/prototype-portable --platform linux-amd64 --phar <path> --runtime <path> --output .cursor/tmp/<dir>

Compatibility wrapper around scripts/build-portable for the original SCI-101
prototype command shape. Prototype outputs must stay under .cursor/tmp/.
USAGE
}

die() {
    echo "Error: $1" >&2
    exit 1
}

platform=""
phar_path=""
runtime_path=""
output_dir=""

while [ "$#" -gt 0 ]; do
    case "$1" in
        --platform)
            platform="${2:-}"
            shift 2
            ;;
        --phar)
            phar_path="${2:-}"
            shift 2
            ;;
        --runtime)
            runtime_path="${2:-}"
            shift 2
            ;;
        --output)
            output_dir="${2:-}"
            shift 2
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            die "Unknown argument: $1"
            ;;
    esac
done

[ -n "$platform" ] || die "--platform is required"
[ -n "$phar_path" ] || die "--phar is required"
[ -n "$runtime_path" ] || die "--runtime is required"
[ -n "$output_dir" ] || die "--output is required"

[ "$platform" = "linux-amd64" ] || die "Only linux-amd64 is supported by this prototype"
[ -f "$phar_path" ] || die "PHAR not found: $phar_path"
case "$output_dir" in
    .cursor/tmp|.cursor/tmp/*) ;;
    *) die "Prototype output must be under .cursor/tmp/" ;;
esac

script_dir=$(CDPATH= cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
output_root=$(dirname -- "$output_dir")
artifact_name=$(basename -- "$output_dir")

"$script_dir/build-portable" \
    --platform "$platform" \
    --phar "$phar_path" \
    --runtime "$runtime_path" \
    --output "$output_root" \
    --name "$artifact_name" >/dev/null

echo "Created portable prototype at $output_dir"
